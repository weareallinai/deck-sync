{
  "name": "deck-sync-monorepo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @deck/web dev",
    "build": "pnpm --filter @deck/web build",
    "start": "pnpm --filter @deck/web start",
    "lint": "pnpm --filter @deck/web lint",
    "test:e2e": "pnpm --filter @deck/web test:e2e",
    "test:e2e:ui": "pnpm --filter @deck/web test:e2e:ui",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "worker:dev": "wrangler dev",
    "worker:deploy": "wrangler deploy",
    "install:all": "pnpm install"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20251004.0",
    "@types/node": "^20",
    "@types/pg": "^8.11.10",
    "dotenv": "^17.2.3",
    "drizzle-kit": "^0.31.2",
    "drizzle-orm": "^0.44.6",
    "pg": "^8.16.3",
    "typescript": "^5",
    "wrangler": "^4.42.0"
  }
}
